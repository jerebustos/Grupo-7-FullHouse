<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/producto.css">
</head>
<body>

  <!-- Encabezado de Navegación -->
  <%- include('../partials/header') %>

  <main class="product-detail-wrapper">
    <article class="product-detail-card">
      <div class="product-detail-gallery">
        <img src="/img/products/<%= productoDetalle.image %>" alt="<%= productoDetalle.name %> - FullHouse" onerror="this.src='/img/FullhouseV7.png'; this.onerror=null;">
      </div>

      <div class="product-detail-content">
        <h1 class="product-detail-title"><%= productoDetalle.name %></h1>

        <div class="product-detail-price">
          $ <%= toThousand(productoDetalle.price) %>
          <span>Envío Gratis</span>
        </div>

        <div class="specs-box">
          <h3>Especificaciones Técnicas</h3>
          <div class="spec-row">
            <span class="spec-label">Marca:</span>
            <span class="spec-val"><%= (productoDetalle && productoDetalle.brand && productoDetalle.brand.name) ? productoDetalle.brand.name : (productoDetalle && productoDetalle.marca ? productoDetalle.marca : 'FullHouse') %></span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Color:</span>
            <span class="spec-val"><%= (productoDetalle && productoDetalle.color && productoDetalle.color.name) ? productoDetalle.color.name : (productoDetalle && productoDetalle.color ? productoDetalle.color : 'N/A') %></span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Modelo:</span>
            <span class="spec-val"><%= productoDetalle.model || productoDetalle.modelo || 'N/A' %></span>
          </div>
          <div class="spec-row">
            <span class="spec-label">Accesorios:</span>
            <span class="spec-val"><%= productoDetalle.accessory || productoDetalle.accesorios || 'Incluidos' %></span>
          </div>
        </div>

        <div class="product-description-box">
          <h3>Descripción del Producto</h3>
          <p><%= productoDetalle.description %></p>
        </div>

        <button class="btn-buy-now" type="button" id="agregar"
                data-id="<%= productoDetalle.id %>"
                data-name="<%= productoDetalle.name %>"
                data-price="<%= productoDetalle.price %>"
                data-image="<%= productoDetalle.image %>">
          <i class="fa-solid fa-cart-plus"></i> Agregar al Carrito
        </button>

        <% if (locals.userLogged && locals.userLogged.admi == 1) { %>
          <div class="admin-actions">
            <a href="/producto/editar/<%= productoDetalle.id %>" class="btn-edit">Editar</a>
            <form action="/producto/borrar/<%= productoDetalle.id %>?_method=DELETE" method="POST" style="flex: 1;">
              <button type="submit" class="btn-delete">Eliminar</button>
            </form>
          </div>
        <% } %>
      </div>
    </article>
  </main>

  <!-- Pie de Página -->
  <%- include('../partials/footer') %>

  <script src="/js/cart.js"></script>
</body>
</html>
