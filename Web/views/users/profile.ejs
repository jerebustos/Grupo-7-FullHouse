<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/profile.css">
</head>
<body>

  <!-- Encabezado de Navegación -->
  <%- include('../partials/header') %>

  <main class="profile-wrapper">
    <article class="profile-card">
      <div class="profile-avatar-container">
        <img src="/img/users/<%= user.avatar %>" alt="Avatar de <%= user.user %>" onerror="this.src='/img/FullhouseV7.png'; this.onerror=null;">
      </div>

      <h1 class="profile-username">@<%= user.user %></h1>

      <div class="profile-details-list">
        <div class="profile-detail-item">
          <span class="profile-label">Nombre Completo:</span>
          <span class="profile-value"><%= user.name %> <%= user.lastName %></span>
        </div>
        <div class="profile-detail-item">
          <span class="profile-label">Correo Electrónico:</span>
          <span class="profile-value"><%= user.email %></span>
        </div>
        <div class="profile-detail-item">
          <span class="profile-label">Dirección:</span>
          <span class="profile-value"><%= user.addres || 'No registrada' %></span>
        </div>
        <div class="profile-detail-item">
          <span class="profile-label">Fecha de Nacimiento:</span>
          <span class="profile-value"><%= user.birth_date || 'No registrada' %></span>
        </div>
      </div>

      <div class="profile-actions">
        <a href="/usuario/editar/<%= user.id %>" class="btn-edit-profile">Editar Datos de Perfil</a>
        
        <form action="/usuario/salir" method="GET">
          <button type="submit" class="btn-logout">Cerrar Sesión</button>
        </form>

        <form action="/usuario/desactivar/<%= user.id %>?_method=DELETE" method="POST">
          <button type="submit" class="btn-delete-account" onclick="return confirm('¿Estás seguro de que deseas eliminar tu cuenta?');">Eliminar Cuenta</button>
        </form>
      </div>
    </article>
  </main>

  <!-- Pie de Página -->
  <%- include('../partials/footer') %>

</body>
</html>