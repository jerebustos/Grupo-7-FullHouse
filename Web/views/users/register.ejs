<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/formularios.css">
</head>
<body>

  <!-- Encabezado de Navegación Principal -->
  <%- include('../partials/header') %>

  <main class="register-wrapper">
    <article class="register-card">
      <div class="card-title-header">
        <h1>Crear una Cuenta en FullHouse</h1>
        <p>Completá el formulario para registrarte y disfrutar de beneficios exclusivos</p>
      </div>

      <form action="/usuario/" method="POST" enctype="multipart/form-data">
        <div class="form-grid">
          
          <div class="field-group">
            <label for="name">Nombre</label>
            <div class="input-wrapper">
              <input type="text" name="name" id="name" placeholder="Tu nombre" value="<%= locals.oldData ? oldData.name : '' %>">
              <i class="fa-solid fa-circle-check status-icon fa-check-circle" id="checkName"></i>
            </div>
            <% if (locals.errors && errors.name) { %>
              <div class="text-danger"><%= errors.name.msg %></div>
            <% } %>
          </div>

          <div class="field-group">
            <label for="lastName">Apellido</label>
            <div class="input-wrapper">
              <input type="text" name="lastName" id="lastName" placeholder="Tu apellido" value="<%= locals.oldData ? oldData.lastName : '' %>">
              <i class="fa-solid fa-circle-check status-icon fa-check-circle" id="checkLastName"></i>
            </div>
            <% if (locals.errors && errors.lastName) { %>
              <div class="text-danger"><%= errors.lastName.msg %></div>
            <% } %>
          </div>

          <div class="field-group">
            <label for="user">Nombre de usuario</label>
            <div class="input-wrapper">
              <input type="text" name="user" id="user" placeholder="Ej. juanperez" value="<%= locals.oldData ? oldData.user : '' %>">
              <i class="fa-solid fa-circle-check status-icon fa-check-circle" id="checkUser"></i>
            </div>
            <% if (locals.errors && errors.user) { %>
              <div class="text-danger"><%= errors.user.msg %></div>
            <% } %>
          </div>

          <div class="field-group">
            <label for="email">Correo Electrónico</label>
            <div class="input-wrapper">
              <input type="email" name="email" id="email" placeholder="correo@ejemplo.com" value="<%= locals.oldData ? oldData.email : '' %>">
              <i class="fa-solid fa-circle-check status-icon fa-check-circle" id="checkEmail"></i>
            </div>
            <% if (locals.errors && errors.email) { %>
              <div class="text-danger"><%= errors.email.msg %></div>
            <% } %>
          </div>

          <div class="field-group">
            <label for="birth_date">Fecha de nacimiento</label>
            <div class="input-wrapper">
              <input type="date" name="birth_date" id="birth_date" value="<%= locals.oldData ? oldData.birth_date : '' %>">
            </div>
            <% if (locals.errors && errors.birth_date) { %>
              <div class="text-danger"><%= errors.birth_date.msg %></div>
            <% } %>
          </div>

          <div class="field-group">
            <label for="addres">Domicilio</label>
            <div class="input-wrapper">
              <input type="text" name="addres" id="addres" placeholder="Calle y número" value="<%= locals.oldData ? oldData.addres : '' %>">
            </div>
            <% if (locals.errors && errors.addres) { %>
              <div class="text-danger"><%= errors.addres.msg %></div>
            <% } %>
          </div>

          <div class="field-group full-width">
            <label for="avatar">Foto de Perfil (Avatar)</label>
            <div class="input-wrapper">
              <input type="file" name="avatar" id="avatar" class="normal" accept="image/*">
            </div>
            <% if (locals.errors && errors.avatar) { %>
              <div class="text-danger"><%= errors.avatar.msg %></div>
            <% } %>
          </div>

          <div class="field-group">
            <label for="pass">Contraseña</label>
            <div class="input-wrapper">
              <input type="password" name="pass" id="pass" placeholder="Mínimo 8 caracteres">
              <i class="fa-solid fa-circle-check status-icon fa-check-circle" id="checkPass"></i>
            </div>
            <% if (locals.errors && errors.pass) { %>
              <div class="text-danger"><%= errors.pass.msg %></div>
            <% } %>
          </div>

          <div class="field-group">
            <label for="passConfirm">Confirmar Contraseña</label>
            <div class="input-wrapper">
              <input type="password" name="pass_confirm" id="passConfirm" placeholder="Repetí tu contraseña">
              <i class="fa-solid fa-circle-check status-icon fa-check-circle" id="checkPassConfirm"></i>
            </div>
            <% if (locals.errors && errors.pass_confirm) { %>
              <div class="text-danger"><%= errors.pass_confirm.msg %></div>
            <% } %>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-submit">Crear mi Cuenta</button>
            <button type="reset" class="btn-reset">Limpiar</button>
          </div>

        </div>
      </form>
    </article>
  </main>

  <!-- Pie de Página -->
  <%- include('../partials/footer') %>

  <script src="/js/scriptRegister.js"></script>
</body>
</html>
