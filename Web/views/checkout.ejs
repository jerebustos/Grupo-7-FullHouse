<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
  <link rel="stylesheet" href="/css/checkout.css">
</head>
<body>

  <!-- Encabezado de Navegación Principal -->
  <%- include('partials/header') %>

  <main class="checkout-wrapper">
    <div class="card-title-header">
      <h1>Finalizar Compra - Pago Seguro</h1>
      <p><i class="fa-solid fa-lock" style="color: #10b981;"></i> Transacción Encriptada SSL de 256-bit</p>
    </div>

    <article class="checkout-card">
      <form action="/" method="GET" class="checkout-grid">
        <!-- Columna 1: Dirección de Envío -->
        <div class="checkout-col">
          <h2 class="checkout-section-title"><i class="fa-solid fa-location-dot"></i> Dirección de Envío</h2>

          <div class="field-group">
            <label for="fname">Nombre y Apellido</label>
            <input type="text" id="fname" name="firstname" placeholder="Ej. Juan Pérez" required>
          </div>

          <div class="field-group">
            <label for="email">Correo Electrónico</label>
            <input type="email" id="email" name="email" placeholder="juan@ejemplo.com" required>
          </div>

          <div class="field-group">
            <label for="adr">Dirección</label>
            <input type="text" id="adr" name="address" placeholder="Av. Corrientes 1234, 4to B" required>
          </div>

          <div class="field-row">
            <div class="field-group">
              <label for="city">Ciudad</label>
              <input type="text" id="city" name="city" placeholder="Buenos Aires" required>
            </div>
            <div class="field-group">
              <label for="zip">Código Postal</label>
              <input type="text" id="zip" name="zip" placeholder="C1043" required>
            </div>
          </div>
        </div>

        <!-- Columna 2: Detalles de Pago -->
        <div class="checkout-col">
          <h2 class="checkout-section-title"><i class="fa-solid fa-credit-card"></i> Información de Pago</h2>

          <div class="card-brands">
            <i class="fa-brands fa-cc-visa" style="color: #1a1f71;"></i>
            <i class="fa-brands fa-cc-mastercard" style="color: #eb001b;"></i>
            <i class="fa-brands fa-cc-amex" style="color: #006fcf;"></i>
          </div>

          <div class="field-group">
            <label for="cname">Nombre en la Tarjeta</label>
            <input type="text" id="cname" name="cardname" placeholder="Como figura en el plástico" required>
          </div>

          <div class="field-group">
            <label for="ccnum">Número de Tarjeta</label>
            <input type="text" id="ccnum" name="cardnumber" placeholder="4509 •••• •••• 1234" required>
          </div>

          <div class="field-row">
            <div class="field-group">
              <label for="expmonth">Vencimiento</label>
              <input type="text" id="expmonth" name="expmonth" placeholder="MM/AA" required>
            </div>
            <div class="field-group">
              <label for="cvv">Código CVV</label>
              <input type="password" id="cvv" name="cvv" placeholder="123" maxlength="4" required>
            </div>
          </div>
        </div>

        <button type="submit" id="pagar" class="btn-pay">
          <i class="fa-solid fa-shield-check"></i> Pagar con Seguridad
        </button>
      </form>
    </article>
  </main>

  <!-- Pie de Página -->
  <%- include('partials/footer') %>

  <script src="/js/pagar.js"></script>
</body>
</html>