<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
  <link rel="stylesheet" href="/css/carrito.css">
</head>
<body>

  <!-- Encabezado de Navegación Principal -->
  <%- include('partials/header') %>

  <main class="cart-wrapper">
    <div class="card-title-header">
      <h1>Tu Carrito de Compras</h1>
    </div>

    <div class="cart-layout">
      <section class="cart-items-box">
        <div class="producto" id="producto">
          <!-- Fallback vació o contenido cargado mediante carrito.js -->
          <div class="empty-cart-state">
            <i class="fa-solid fa-basket-shopping empty-cart-icon"></i>
            <h3>Tu carrito está vacío</h3>
            <p>Descubrí miles de productos en oferta en nuestra tienda.</p>
            <a href="/producto" class="btn-catalog">Explorar Catálogo <i class="fa-solid fa-arrow-right"></i></a>
          </div>
        </div>
      </section>

      <aside class="order-summary-box">
        <h2 class="summary-title">Resumen de Compra</h2>
        
        <div class="summary-row">
          <span>Subtotal</span>
          <strong id="subTotal">$0</strong>
        </div>
        
        <div class="summary-row">
          <span>Envío</span>
          <span style="color: #10b981; font-weight: 600;">Gratis</span>
        </div>

        <div class="summary-row total-row">
          <span>Total</span>
          <strong class="total-price" id="total">$0</strong>
        </div>

        <form action="/checkout" method="GET">
          <button class="btn-checkout" type="submit">Finalizar Compra</button>
        </form>
        
        <form action="/" method="GET">
          <button class="btn-continue" type="submit">Continuar Comprando</button>
        </form>
      </aside>
    </div>
  </main>

  <!-- Pie de Página -->
  <%- include('partials/footer') %>

  <script src="/js/carrito.js"></script>
</body>
</html>
